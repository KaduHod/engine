<%
  // Monta o grid-template-columns baseado nos tipos das colunas visíveis
  const colunasVisiveis = entidade.colunas.filter(c => !c.hidden);
  const gridCols = colunasVisiveis.map(c => {
    if (c.pk || c.tipo === 'boolean') return 'min-content';
    return 'minmax(min-content, 1fr)';
  }).join(' ') + ' min-content'; // última coluna: ações
%>
  <%# ── Container de itens ── %>
  <div id="itens-container">
    <% if (itens && itens.length > 0) { %>
      <% itens.forEach((item, index) => { %>

        <%# ── MOBILE: card empilhado | DESKTOP: linha em grid ── %>
        <div data-item="true"
             data-id="<%= index %>"
             class="border border-gray-300 rounded-lg p-4 mb-3 bg-white shadow-sm
                    md:rounded-none md:p-0 md:mb-0 md:shadow-none md:border-0 md:border-b
                    md:grid md:items-center md:gap-2 md:px-2 md:hover:bg-gray-50"
             style="grid-template-columns: <%= gridCols %>">

          <%# Campos hidden %>
          <% entidade.colunas.filter(c => c.hidden).forEach(coluna => { %>
            <input type="hidden" name="<%= coluna.nome %>" value="<%= item[coluna.nome] || '' %>">
          <% }) %>

          <%# Campos visíveis %>
          <% colunasVisiveis.forEach(coluna => { %>

            <% if (coluna.pk) { %>
              <%# PK: clicável, redireciona %>
              <div hx-get="<%= entidade.http_path_name + '/' + item[coluna.nome] %>"
                   hx-target="main"
                   hx-swap="innerHTML"
                   data-link
                   class="flex items-center h-[44px] p-2 rounded cursor-pointer">
                <span class="text-sm" data-item-pk="true"><%= item[coluna.nome] || '' %></span>
              </div>

            <% } else { %>
              <%
                let inputType = 'text';
                if (coluna.tipo === 'number')  inputType = 'number';
                if (coluna.tipo === 'boolean') inputType = 'checkbox';
              %>

              <%# Wrapper: em mobile mostra label em cima, em desktop some com o label %>
              <div class="mb-3 md:mb-0 md:py-1">
                <label class="block text-xs font-medium text-gray-500 mb-1 md:hidden">
                  <%= coluna.label ?? coluna.nome %>
                </label>

                <% if (inputType === 'checkbox') { %>
                  <div class="flex md:justify-center">
                    <input type="checkbox"
                           class="h-5 w-5"
                           name="<%= coluna.nome %>[]"
                           <%= item[coluna.nome] ? 'checked' : '' %>>
                  </div>

                <% } else if (coluna.tipo === 'label') { %>
                  <div class="flex items-center h-[44px] p-2 rounded">
                    <span class="text-sm" data-item-label="true"><%= item[coluna.nome] || '' %></span>
                  </div>
                <% } else if (coluna.search) { %>
                  <div class="relative" data-search-field>
                    <input
                      type="text"
                      hx-post="/<%= entidade.http_path_name %>/search?coluna=<%= coluna.nome %>"
                      hx-trigger="keyup changed delay:500ms"
                      hx-target="next ul"
                      hx-params="busca"
                      hx-vals='js:{ "busca": document.activeElement.value }'
                      hx-swap="innerHTML"
                      placeholder="Digite para buscar..."
                      class="w-full p-2 border border-gray-300 rounded-md text-sm"
                      autocomplete="off"
                      value="<%= item[coluna.nome] %>"
                      data-search-input
                    >
                    <ul class="hidden absolute z-10 w-full bg-white border border-gray-300 rounded-md shadow-sm mt-1 max-h-48 overflow-y-auto" data-search-dropdown></ul>
                    <input type="hidden" name="<%= coluna.nome %>_id" value="<%= item[coluna.nome + '_id'] || '' %>" data-search-hidden>
                  </div>
                <% } else { %>
                <input
                    type="<%= inputType %>"
                    data-nome="<%= coluna.nome %>"
                    data-valor="<%= item[coluna.nome] %>"
                    class="w-full p-2 border rounded min-h-[44px] text-sm <%= coluna.pk ? 'bg-gray-100' : '' %>"
                    name="<%= coluna.nome %>[]"
                    value="<%= item[coluna.nome] || '' %>">
                <% } %>
              </div>
            <% } %>

          <% }) %>

          <%# Ações (excluir) %>
          <div class="md:flex md:justify-center md:py-1">
            <label class="block text-xs font-medium text-gray-500 mb-1 md:hidden">Excluir</label>
            <input data-remove-item="true" type="checkbox" name="excluir"
                   class="cursor-pointer h-5 w-5 border-gray-400 bg-white text-apple-blue">
          </div>

        </div>

      <% }) %>
    <% } %>
<%# ── Paginação ── %>
<% if (typeof pagina !== 'undefined' && typeof total !== 'undefined' && pagina) { %>
  <%
    const totalPaginas = Math.ceil(total / itens_por_pagina);
  %>
  <div class="mt-4 flex items-center gap-2">
    <button
      type="button"
      hx-get="/<%= entidade.http_path_name %>?pagina=<%= pagina - 1 %>"
      hx-target="main"
      hx-swap="innerHTML"
      <%= pagina <= 1 ? 'disabled' : '' %>
      class="px-4 py-2 rounded text-sm min-h-[44px] <%= pagina <= 1 ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : 'bg-gray-200 hover:bg-gray-300' %>"
    >
      ←
    </button>

    <span class="text-sm text-gray-600 px-2">
        <%= pagina %> de <%= totalPaginas %>
    </span>

    <button
      type="button"
      hx-get="/<%= entidade.http_path_name %>?pagina=<%= pagina + 1 %>"
      hx-target="main"
      hx-swap="innerHTML"
      <%= pagina >= totalPaginas ? 'disabled' : '' %>
      class="px-4 py-2 rounded text-sm min-h-[44px] <%= pagina >= totalPaginas ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : 'bg-gray-200 hover:bg-gray-300' %>"
    >
        →
    </button>
  </div>
<% } %>
  </div>

