<div class="container mx-auto p-4">
  <h1 class="text-xl font-bold mb-4"><%= entidade.nome %></h1>
  <form id="form-<%= entidade.nome %>" class="space-y-4">
    <%# Desktop: tabela normal | Mobile: escondida, usa cards %>
    <div class="hidden md:block overflow-x-auto">
      <table class="min-w-full border-collapse border border-gray-300">
        <thead>
          <tr class="bg-gray-100">
            <% entidade.colunas.filter(c => !c.hidden).forEach(coluna => { %>
              <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium">
                <%= coluna.label ?? coluna.nome %>
                <% if (coluna.pk) { %>(PK)<% } %>
                <% if (coluna.fk) { %>(FK)<% } %>

              </th>
            <% }) %>
            <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium">Ações</th>
          </tr>
        </thead>
        <tbody id="itens-container-desktop">
          <% if (itens && itens.length > 0) { %>
            <% itens.forEach((item, index) => { %>
              <tr class="hover:bg-gray-50" data-index="<%= index %>">
                  <% entidade.colunas.filter(c => c.hidden).forEach(coluna => { %>
                        <input type="hidden" name="<%= coluna.nome %>" value="<%= item[coluna.nome] || '' %>">
                   <% }) %>
                  <% entidade.colunas.filter(c => !c.hidden).forEach(coluna => { %>
                  <td class="border border-gray-300 px-4 py-2">
                    <%
                      let inputType = 'text';
                      let inputClass = 'w-full p-2 border rounded min-h-[44px]';
                    if(coluna.hidden) {
                        inputType = 'hidden';
                        inputClass = 'hidden';
                    } else {
                      if (coluna.tipo === 'number') inputType = 'number';
                      if (coluna.tipo === 'boolean') {
                        inputType = 'checkbox';
                        inputClass = 'h-5 w-5 mx-auto block';
                      }
                    }
                    %>
                    <% if (coluna.pk) { %>
                      <input type="<%= inputType %>" class="<%= inputClass %> bg-gray-100" name="<%= coluna.nome %>[]" value="<%= item[coluna.nome] || '' %>" readonly>
                    <% } else if (inputType === 'checkbox') { %>
                      <div class="flex justify-center">
                        <input type="checkbox" class="<%= inputClass %>" name="<%= coluna.nome %>[]" <%= item[coluna.nome] ? 'checked' : '' %>>
                      </div>
                    <% } else { %>
                      <input type="<%= inputType %>" class="<%= inputClass %>" name="<%= coluna.nome %>[]" value="<%= item[coluna.nome] || '' %>">
                    <% } %>
                  </td>
                <% }) %>
                <td class="border border-gray-300 px-4 py-2">
                  <button type="button" class="remover-item text-red-500 text-sm hover:underline" data-index="<%= index %>">Remover</button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <%# Mobile: layout de cards %>
    <div class="md:hidden" id="itens-container-mobile">
      <% if (itens && itens.length > 0) { %>
        <% itens.forEach((item, index) => { %>
          <div class="border border-gray-300 rounded-lg p-4 mb-3 bg-white shadow-sm" data-index="<%= index %>">

            <% entidade.colunas.filter(c => c.hidden).forEach(coluna => { %>
                <input type="hidden" name="<%= coluna.nome %>" value="<%= item[coluna.nome] || '' %>">
            <% }) %>
            <% entidade.colunas.filter(c => !c.hidden).forEach(coluna => { %>
              <%
                      let inputType = 'text';
                    if(coluna.hidden) {
                        inputType = 'hidden';
                        inputClass = 'hidden';
                    } else {
                      if (coluna.tipo === 'number') inputType = 'number';
                      if (coluna.tipo === 'boolean') {
                        inputType = 'checkbox';
                      }
                    }
              %>
              <div class="mb-3">
                <label class="block text-xs font-medium text-gray-500 mb-1">
                  <%= coluna.label ?? coluna.nome %>
                  <% if (coluna.pk) { %><span class="text-blue-500">(PK)</span><% } %>
                  <% if (coluna.fk) { %><span class="text-purple-500">(FK)</span><% } %>
                </label>
                <% if (inputType === 'checkbox') { %>
                  <input type="checkbox" class="h-5 w-5" name="<%= coluna.nome %>[]" <%= item[ coluna.label ?? coluna.nome] ? 'checked' : '' %> <% if (coluna.pk) { %>readonly<% } %>>
                <% } else { %>
                  <input
                    type="<%= inputType %>"
                    class="w-full p-2 border rounded min-h-[44px] text-sm <%= coluna.pk ? 'bg-gray-100' : '' %>"
                    name="<%= coluna.nome %>[]"
                    value="<%= item[coluna.label ?? coluna.nome] || '' %>"
                    <% if (coluna.pk) { %>readonly<% } %>
                  >
                <% } %>
              </div>
            <% }) %>
            <button type="button" class="remover-item w-full mt-2 text-red-500 text-sm border border-red-200 rounded py-2 hover:bg-red-50">
              Remover item
            </button>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <button
        type="button"
        id="adicionar-item"
        class="w-full sm:w-auto bg-blue-500 text-white px-6 py-3 rounded hover:bg-blue-600 min-h-[44px]"
      >
        + Adicionar Linha
      </button>
      <button
        type="submit"
        class="w-full sm:w-auto bg-green-500 text-white px-6 py-3 rounded hover:bg-green-600 min-h-[44px]"
      >
        Salvar Tabela
      </button>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('form-<%= entidade.nome %>');
  const desktopContainer = document.getElementById('itens-container-desktop');
  const mobileContainer  = document.getElementById('itens-container-mobile');
  const isMobile = () => window.innerWidth < 768;

  <%# Templates de nova linha (desktop) e novo card (mobile) %>
  const novaLinhaDesktop = `
    <tr class="hover:bg-gray-50">
      <% entidade.colunas.forEach(coluna => { %>
        <td class="border border-gray-300 px-4 py-2">
          <%
            let inputType = 'text';
            let inputClass = 'w-full p-2 border rounded min-h-[44px]';
            if (coluna.tipo === 'number') inputType = 'number';
            if (coluna.tipo === 'boolean') {
              inputType = 'checkbox';
              inputClass = 'h-5 w-5 mx-auto block';
            }
          %>
          <% if (coluna.pk) { %>
            <input type="<%= inputType %>" class="<%= inputClass %> bg-gray-100" name="<%= coluna.nome %>[]" value="" readonly>
          <% } else if (inputType === 'checkbox') { %>
            <div class="flex justify-center">
              <input type="checkbox" class="<%= inputClass %>" name="<%= coluna.nome %>[]">
            </div>
          <% } else { %>
            <input type="<%= inputType %>" class="<%= inputClass %>" name="<%= coluna.nome %>[]">
          <% } %>
        </td>
      <% }) %>
      <td class="border border-gray-300 px-4 py-2">
        <button type="button" class="remover-item text-red-500 text-sm hover:underline">Remover</button>
      </td>
    </tr>
  `;

  const novoCardMobile = `
    <div class="border border-gray-300 rounded-lg p-4 mb-3 bg-white shadow-sm">
      <% entidade.colunas.forEach(coluna => { %>
        <%
          let inputType = 'text';
          if (coluna.tipo === 'number') inputType = 'number';
          if (coluna.tipo === 'boolean') inputType = 'checkbox';
        %>
        <div class="mb-3">
          <label class="block text-xs font-medium text-gray-500 mb-1">
            <%= coluna.nome %>
            <% if (coluna.pk) { %><span class="text-blue-500">(PK)</span><% } %>
            <% if (coluna.fk) { %><span class="text-purple-500">(FK)</span><% } %>
          </label>
          <% if (inputType === 'checkbox') { %>
            <input type="checkbox" class="h-5 w-5" name="<%= coluna.nome %>[]" <% if (coluna.pk) { %>readonly<% } %>>
          <% } else { %>
            <input
              type="<%= inputType %>"
              class="w-full p-2 border rounded min-h-[44px] text-sm <%= coluna.pk ? 'bg-gray-100' : '' %>"
              name="<%= coluna.nome %>[]"
              <% if (coluna.pk) { %>readonly<% } %>
            >
          <% } %>
        </div>
      <% }) %>
      <button type="button" class="remover-item w-full mt-2 text-red-500 text-sm border border-red-200 rounded py-2 hover:bg-red-50">
        Remover item
      </button>
    </div>
  `;

  document.getElementById('adicionar-item').addEventListener('click', function() {
    if (isMobile()) {
      const div = document.createElement('div');
      div.innerHTML = novoCardMobile;
      mobileContainer.appendChild(div.firstElementChild);
    } else {
      const tr = document.createElement('tr');
      tr.innerHTML = novaLinhaDesktop;
      desktopContainer.appendChild(tr);
    }
  });

  // Delegação de eventos para ambos os containers
  [desktopContainer, mobileContainer].forEach(container => {
    if (!container) return;
    container.addEventListener('click', function(e) {
      if (e.target.classList.contains('remover-item')) {
        const row = e.target.closest('tr') || e.target.closest('[data-index], div.border');
        if (row) row.remove();
      }
    });
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(form);
    const data = {};
    for (let [key, value] of formData.entries()) {
      if (!data[key]) data[key] = [];
      data[key].push(value);
    }
    console.log('Dados do formulário:', data);
    alert('Formulário enviado! Verifique o console para os dados.');
  });
});
</script>

